# =============================================================================
# Shuyu — Agentic Data Analyst 环境配置
# =============================================================================
# 使用方法: cp .env.example .env  然后编辑 .env 文件
# =============================================================================

# ── LLM 配置（必须） ──────────────────────────────────────────────────────────
# 支持的 provider: openai, deepseek, anthropic, ollama
LLM_API_KEY=sk-your-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_API_BASE=https://api.openai.com/v1

# ── MySQL ConfigDB 配置（生产环境必须） ─────────────────────────────────────────
# 本地开发可留空，后端自动使用 SQLite
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
CONFIGDB_URL=mysql+pymysql://shuyu:ShuyuPass123@mysql:3306/shuyu_config?charset=utf8mb4

# MySQL 服务配置（仅 docker compose 使用）
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_DATABASE=shuyu_config
MYSQL_USER=shuyu
MYSQL_PASSWORD=ShuyuPass123

# ── 认证安全配置（生产环境必须） ─────────────────────────────────────────────────
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(48))"
# AUTH_SECRET_KEY=

# ── 可选配置 ──────────────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# AUTH_EXPIRE_MINUTES=1440
